            "mode": "all",
            "conditions": [
              { "metric": "totalShortage", "operator": "gte", "target": 9000, "label": "长期有太多居民用不上电" }
            ]
          },
          "action": { "type": "adjustState", "field": "satisfaction", "amountPerHour": -0.12 }
        }
      ],
      "objective": {
        "label": "居民满意达到 92%，并治理到第 3 天",
        "mode": "all",
        "conditions": [
          { "metric": "satisfaction", "operator": "gte", "target": 92, "label": "居民满意达到 92%" },
          { "metric": "day", "operator": "gte", "target": 3, "label": "治理到第 3 天" }
